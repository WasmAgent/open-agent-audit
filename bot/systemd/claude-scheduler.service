[Unit]
Description=Claude GitHub Scheduler
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=claudebot
WorkingDirectory=/srv/claude-bot
EnvironmentFile=/etc/claude-bot/claude-bot.env
ExecStart=/usr/bin/python3 /srv/claude-bot/scheduler.py
Restart=always
RestartSec=10

NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/srv/claude-bot /tmp

[Install]
WantedBy=multi-user.target
