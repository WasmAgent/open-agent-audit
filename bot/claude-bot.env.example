# /etc/claude-bot/claude-bot.env
# Copy to /etc/claude-bot/claude-bot.env and fill in real values.
# systemd EnvironmentFile does not need `export`.

DB_PATH="/srv/claude-bot/db.sqlite3"
REPOS_CONFIG_PATH="/srv/claude-bot/repos.yml"

POLL_INTERVAL="120"
LEASE_MINUTES="60"

MAX_RETRIES="5"
MAX_CI_RETRIES="3"
MAX_REVIEW_RETRIES="2"

PROVIDER="zai-glm"
BILLING_MODE="zai_personal_pro"
ACCOUNT_MODE="zai_personal_pro"
KEY_TYPE="personal_coding_plan_key"
BILLING_LAST_VERIFIED_AT="2026-06-28"

RATE_LIMIT_DEFAULT_COOLDOWN_MINUTES="30"
OVERLOAD_COOLDOWN_MINUTES="10"
RESET_TIME_BUFFER_MINUTES="2"
SUCCESS_TO_RESTORE_CONCURRENCY="3"

ENABLE_WIP_CHECKPOINT="1"
PUSH_WIP_CHECKPOINT="0"

CLAUDE_CODE_DISABLE_WORKFLOWS="1"

MCP_CONFIG_PATH="/srv/claude-bot/empty-mcp.json"

MAX_ENABLED_WORKERS="1"
MAX_TOTAL_JOBS_PER_DAY="200"
MAX_NORMAL_JOBS_PER_DAY="195"
MAX_HARD_JOBS_PER_DAY="5"
MAX_ULTRACODE_JOBS_PER_DAY="0"
MAX_WEEKLY_ULTRACODE_JOBS="2"
HIGH_COST_TASK_PAUSE_WINDOW_JST="15:00-19:00"

# Fill in real GitHub App token or fine-grained PAT
GH_TOKEN="REPLACE_WITH_REAL_TOKEN"

# Z.AI Coding Plan API key — set in /home/claudebot/.claude/settings.json instead,
# so it is not visible in process environment.
# ZAI_API_KEY="REPLACE_WITH_REAL_KEY"
