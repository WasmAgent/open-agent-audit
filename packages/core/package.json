{
  "name": "@openagentaudit/core",
  "version": "0.1.0",
  "description": "OpenAgentAudit audit engines: validate, inventory, policy-audit, benchmark-audit, contamination, drift-guard, scoring, report",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./benchmark-audit": "./dist/benchmark-audit/index.js",
    "./contamination": "./dist/contamination/index.js",
    "./drift-guard": "./dist/drift-guard/index.js",
    "./inventory": "./dist/inventory/index.js",
    "./policy-audit": "./dist/policy-audit/index.js",
    "./report": "./dist/report/index.js",
    "./scoring": "./dist/scoring/index.js",
    "./validate": "./dist/validate/index.js"
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test ./src",
    "clean": "rm -rf dist .turbo"
  },
  "wasmagent": {
    "stability": "alpha"
  },
  "dependencies": {
    "@openagentaudit/schema": "0.1.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14"
  }
}
