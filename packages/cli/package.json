  },
  "wasmagent": { "stability": "alpha" },
  "dependencies": {
    "@openagentaudit/core": "0.1.0",
    "@openagentaudit/adapters": "0.1.0",
    "@openagentaudit/schema": "0.1.0"
  }
}
