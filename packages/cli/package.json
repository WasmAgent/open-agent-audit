{
  "name": "@openagentaudit/cli",
  "version": "0.1.0",
  "description": "OpenAgentAudit local CLI (Bun-first)",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "main": "./dist/main.js",
  "bin": {
    "openagentaudit": "./dist/main.js"
  },
