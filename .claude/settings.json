{
  "permissions": {
    "deny": [
      "Bash(git push *)",
      "Bash(git commit *)",
      "Bash(git tag *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -fd *)",
      "Bash(git worktree *)",

      "Bash(gh pr merge *)",
      "Bash(gh repo delete *)",
      "Bash(gh secret *)",

      "Bash(npm publish *)",
      "Bash(bun publish *)",
      "Bash(pnpm publish *)",
      "Bash(yarn publish *)",

      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(rsync *)",
      "Bash(nc *)",
      "Bash(telnet *)",

      "Bash(rm -rf /*)",
      "Bash(find * -delete *)",

      "Read(~/.ssh/**)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Read(~/.pypirc)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git push *)",
            "command": "/srv/claude-bot/bin/bash-guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(git commit *)",
            "command": "/srv/claude-bot/bin/bash-guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(gh pr merge *)",
            "command": "/srv/claude-bot/bin/bash-guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(npm publish *)",
            "command": "/srv/claude-bot/bin/bash-guard.sh"
          }
        ]
      }
    ]
  }
}
