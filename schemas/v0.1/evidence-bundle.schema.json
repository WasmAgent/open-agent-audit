{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.openagentaudit.org/v0.1/evidence-bundle.schema.json",
  "title": "OpenAgentAudit Evidence Bundle Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "bundle_id",
    "run_id",
    "generated_at",
    "engine_version",
    "spec_version",
    "files"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "open-agent-audit/v0.1" },
    "bundle_id": { "type": "string" },
    "run_id": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "engine_version": { "type": "string" },
    "spec_version": { "type": "string" },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "sha256", "size_bytes"],
        "additionalProperties": false,
        "properties": {
          "path": { "type": "string" },
          "sha256": { "type": "string", "pattern": "^[A-Fa-f0-9]{64}$" },
          "size_bytes": { "type": "integer", "minimum": 0 },
          "media_type": { "type": "string" }
        }
      }
    },
    "signer_key_id": { "type": "string" },
    "signature_algorithm": {
      "type": "string",
      "enum": ["ed25519", "ecdsa-p256"]
    },
    "profile_versions": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  }
}
