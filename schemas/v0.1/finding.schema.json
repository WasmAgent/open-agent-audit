{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.openagentaudit.org/v0.1/finding.schema.json",
  "title": "OpenAgentAudit Finding",
  "description": "Structured output of an audit rule.",
  "type": "object",
  "required": [
    "schema_version",
    "finding_id",
    "rule_id",
    "severity",
    "category",
    "title",
    "description",
    "evidence_ids",
    "recommendation"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "open-agent-audit/v0.1" },
    "finding_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._-]+$"
    },
    "rule_id": {
      "type": "string",
      "pattern": "^OAA-R-[A-Z0-9-]+$"
    },
    "severity": {
      "type": "string",
      "enum": ["info", "low", "medium", "high", "critical"]
    },
    "category": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "evidence_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "recommendation": { "type": "string", "minLength": 1 },
    "standard_mappings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["profile", "control_id", "limitation"],
        "additionalProperties": false,
        "properties": {
          "profile": { "type": "string" },
          "control_id": { "type": "string" },
          "limitation": { "type": "string", "minLength": 1 }
        }
      }
    },
    "confidence": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "false_positive_likelihood": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "first_seen": { "type": "string", "format": "date-time" },
    "last_seen": { "type": "string", "format": "date-time" },
    "occurrence_count": { "type": "integer", "minimum": 1 },
    "suppressed": { "type": "boolean" },
    "suppression_reason": { "type": "string" }
  },
  "allOf": [
    {
      "if": { "properties": { "suppressed": { "const": true } } },
      "then": { "required": ["suppression_reason"] }
    }
  ]
}
