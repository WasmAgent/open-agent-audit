{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.openagentaudit.org/v0.1/risk-score.schema.json",
  "title": "OpenAgentAudit Risk Score",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "evidence_admission_score",
    "agent_risk_score",
    "components",
    "generated_at"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "open-agent-audit/v0.1" },
    "run_id": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "evidence_admission_score": {
      "type": "object",
      "required": ["score", "grade"],
      "additionalProperties": false,
      "properties": {
        "score": { "type": "number", "minimum": 0, "maximum": 100 },
        "grade": { "type": "string", "enum": ["A", "B", "C", "D", "F"] }
      }
    },
    "agent_risk_score": {
      "type": "object",
      "required": ["score"],
      "additionalProperties": false,
      "properties": {
        "score": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    },
    "components": {
      "type": "object",
      "additionalProperties": { "type": "number" },
      "properties": {
        "trace_completeness": { "type": "number", "minimum": 0, "maximum": 100 },
        "provenance_integrity": { "type": "number", "minimum": 0, "maximum": 100 },
        "objective_verification": { "type": "number", "minimum": 0, "maximum": 100 },
        "policy_coverage": { "type": "number", "minimum": 0, "maximum": 100 },
        "human_oversight_evidence": { "type": "number", "minimum": 0, "maximum": 100 },
        "contamination_risk": { "type": "number", "minimum": 0, "maximum": 100 },
        "action_risk": { "type": "number" },
        "permission_risk": { "type": "number" },
        "data_risk": { "type": "number" },
        "autonomy_risk": { "type": "number" },
        "failure_risk": { "type": "number" },
        "drift_risk": { "type": "number" },
        "mitigation_credit": { "type": "number" }
      }
    },
    "rubric_version": { "type": "string" }
  }
}
