{
  // OpenAgentAudit — Cloudflare Worker reference configuration
  //
  // CI/CD: this file is used directly by .github/workflows/deploy.yml
  // The CI job replaces REPLACE_ME_D1_ID with the CF_D1_DATABASE_ID secret.
  //
  // Manual deploy:
  //   1. Copy to `wrangler.jsonc` (gitignored).
  //   2. Replace REPLACE_ME_D1_ID with your D1 database ID.
  //   3. Adjust "routes" to your custom domain, or remove the block entirely
  //      to deploy to workers.dev only.
  //   4. Build packages: schema → core → adapters → dashboard
  //   5. wrangler deploy --config wrangler.jsonc

  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "open-agent-audit",
  "main": "packages/worker/src/index.ts",
  "compatibility_date": "2026-06-26",
  "compatibility_flags": ["nodejs_compat"],

  "assets": {
    "directory": "./packages/dashboard/dist/",
    "not_found_handling": "single-page-application",
    "binding": "ASSETS",
    "run_worker_first": true
  },

  "routes": [
    { "pattern": "trustavo.com", "custom_domain": true }
  ],

  "r2_buckets": [
    { "binding": "RAW_TRACES", "bucket_name": "oaa-raw-traces" },
    { "binding": "ARTIFACTS",  "bucket_name": "oaa-artifacts"  },
    { "binding": "REPORTS",    "bucket_name": "oaa-reports"    }
  ],

  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "oaa-meta",
      "database_id": "REPLACE_ME_D1_ID"
    }
  ],

  "queues": {
    "producers": [
      { "binding": "AUDIT_JOBS",  "queue": "oaa-audit-jobs"  },
      { "binding": "CHUNK_JOBS",  "queue": "oaa-chunk-jobs"  },
      { "binding": "REPORT_JOBS", "queue": "oaa-report-jobs" }
    ],
    "consumers": [
      { "queue": "oaa-audit-jobs",  "max_batch_size": 10, "max_batch_timeout": 30 },
      { "queue": "oaa-chunk-jobs",  "max_batch_size": 10, "max_batch_timeout": 30 },
      { "queue": "oaa-report-jobs", "max_batch_size":  5, "max_batch_timeout": 30 }
    ]
  },

  "durable_objects": {
    "bindings": [
      { "name": "AUDIT_RUN_COORDINATOR", "class_name": "AuditRunCoordinator" },
      { "name": "TENANT_LIMITER",        "class_name": "TenantLimiter"        }
    ]
  },

  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["AuditRunCoordinator", "TenantLimiter"] }
  ],

  "vars": {
    "OAA_ENV": "production",
    "MAX_UPLOAD_MB": "100",
    "DEFAULT_PROFILES": "owasp-agentic-top10-2026,nist-ai-rmf-1.0"
  }
}
